generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClasseRisco {
  I
  II
  III
  IV
}

enum Apresentacao {
  AMPOLA
  FRASCO
  CAIXA
  SACHE
  BOLSA
  SERINGA
  TUBO
  BLISTER
  BOMBONA
  LATA
  GALERIA
  UNIDADE
  OUTRA
}

enum StatusLote {
  DISPONIVEL
  QUARENTENA
  BLOQUEADO
  VENCIDO
}

model Usuario {
  id               Int                   @id @default(autoincrement())
  nome             String
  email            String                @unique
  senha            String
  perfil           PerfilUsuario         @default(VENDAS)
  ativo            Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  historicosPedido HistoricoPedido[]
  movimentacoes    MovimentacaoEstoque[]
  vendedor         Vendedor?
}

model Produto {
  id                       Int                   @id @default(autoincrement())
  codigoInterno            String?
  codigoBarras             String?
  descricao                String
  categoria                String?
  fabricante               String?
  unidadeVenda             String?
  unidadeCompra            String?
  fatorConversao           Float?                @default(1)
  registroAnvisa           String?
  temperaturaArmazenamento String?
  controlaValidade         Boolean               @default(false)
  controlaLote             Boolean               @default(false)
  precoCustoBase           Float                 @default(0)
  precoVendaBase           Float                 @default(0)
  ativo                    Boolean               @default(true)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  categoriaId              Int?
  estoqueMinimo            Float                 @default(0)
  
  cnpjFabricante           String?
  classeRisco              ClasseRisco?
  codigoFabricante         String?
  apresentacao             Apresentacao?
  concentracaoValor        Float?
  concentracaoUnidade      String?
  principioAtivo           String?
  marca                    String?
  conteudoEmbalagem        Int?
  localizacaoEstoque       String?
  pontoReposicao           Float?
  
  estoqueAtual             EstoqueAtual[]
  itensCompra              ItemPedidoCompra[]
  itensVenda               ItemPedidoVenda[]
  itensSeparacao           ItemSeparacao[]
  itensTabela              ItemTabelaPreco[]
  lotes                    Lote[]
  movimentacoes            MovimentacaoEstoque[]
  movimentacoesFiscais     MovimentacaoFiscal[]
  categoriaRef             Categoria?            @relation(fields: [categoriaId], references: [id])

  ncm                   String?   // 8 dígitos
  cfop                  String?   // 4 dígitos
  cst                   String?   // regime Normal
  csosn                 String?   // Simples Nacional
  origemMercadoria      String?   // 0=nacional, 1=importado
  aliquotaIcms          Float?
  aliquotaIpi           Float?
  aliquotaPis           Float?
  aliquotaCofins        Float?
  unidadeFiscal         String?   // UN, CX, FR, KG — pode diferir da unidadeVenda

  @@index([categoriaId])
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nome      String
  ativo     Boolean    @default(true)
  empresaId Int
  parentId  Int?
  produtos  Produto[]
  parent    Categoria? @relation("CategoriaHierarchy", fields: [parentId], references: [id])
  children  Categoria[] @relation("CategoriaHierarchy")

  @@index([parentId])
  @@index([empresaId])
}

model Localizacao {
  id            Int                   @id @default(autoincrement())
  nome          String                @unique
  createdAt     DateTime              @default(now())
  estoqueAtual  EstoqueAtual[]
  lotes         Lote[]
  movimentacoes MovimentacaoEstoque[]
}

model Lote {
  id                   Int                   @id @default(autoincrement())
  produtoId            Int
  numeroLote           String
  validade             DateTime?
  localizacaoId        Int?
  createdAt            DateTime              @default(now())
  fornecedorId         Int?
  enderecoEstoque      String?
  status               StatusLote            @default(DISPONIVEL)
  precoCusto           Float?
  estoqueAtual         EstoqueAtual[]
  itensSeparacao       ItemSeparacao[]
  fornecedor           Fornecedor?           @relation(fields: [fornecedorId], references: [id])
  localizacaoRef       Localizacao?          @relation(fields: [localizacaoId], references: [id])
  produto              Produto               @relation(fields: [produtoId], references: [id])
  movimentacoes        MovimentacaoEstoque[]
  movimentacoesFiscais MovimentacaoFiscal[]

  @@unique([numeroLote, produtoId])
  @@index([produtoId])
  @@index([localizacaoId])
  @@index([fornecedorId])
}

model MovimentacaoEstoque {
  id                 Int                 @id @default(autoincrement())
  produtoId          Int
  loteId             Int?
  localizacaoId      Int?
  tipo               TipoMovimentacao
  quantidade         Float
  usuario            String              @default("Administrador")
  observacao         String?
  createdAt          DateTime            @default(now())
  destino            String?
  origem             String?
  pedidoVendaId      Int?
  usuarioId          Int?
  empresaFiscalId    Int?
  localizacao        Localizacao?        @relation(fields: [localizacaoId], references: [id])
  lote               Lote?               @relation(fields: [loteId], references: [id])
  pedidoVenda        PedidoVenda?        @relation(fields: [pedidoVendaId], references: [id])
  produto            Produto             @relation(fields: [produtoId], references: [id])
  usuarioRef         Usuario?            @relation(fields: [usuarioId], references: [id])
  empresaFiscal      EmpresaFiscal?      @relation(fields: [empresaFiscalId], references: [id])
  movimentacaoFiscal MovimentacaoFiscal?

  @@index([produtoId])
  @@index([loteId])
  @@index([localizacaoId])
  @@index([pedidoVendaId])
  @@index([usuarioId])
  @@index([empresaFiscalId])
  @@index([createdAt])
}

model EstoqueAtual {
  id                   Int           @id @default(autoincrement())
  produtoId            Int
  loteId               Int?
  localizacaoId        Int?
  quantidadeDisponivel Float         @default(0)
  quantidadeReservada  Float         @default(0)
  quantidadeBloqueada  Float         @default(0)
  updatedAt            DateTime      @updatedAt
  createdAt            DateTime      @default(now())
  custoUnitario        Float         @default(0)
  status               StatusEstoque @default(DISPONIVEL)
  localizacao          Localizacao?  @relation(fields: [localizacaoId], references: [id])
  lote                 Lote?         @relation(fields: [loteId], references: [id])
  produto              Produto       @relation(fields: [produtoId], references: [id])

  @@index([produtoId])
  @@index([loteId])
  @@index([localizacaoId])
}

model Fornecedor {
  id                Int               @id @default(autoincrement())
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String?           @unique
  email             String?
  telefone          String?
  endereco          String?
  cidade            String?
  estado            String?
  cep               String?
  ativo             Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  contasPagar       Conta[]
  documentosFiscais DocumentoFiscal[]
  pedidosCompra     PedidoCompra[]
  lotes              Lote[]
}

model Cliente {
  id                   Int                  @id @default(autoincrement())
  razaoSocial          String
  nomeFantasia         String?
  cnpjCpf              String?              @unique
  email                String?
  telefone             String?
  endereco             String?
  cidade               String?
  estado               String?
  cep                  String?
  limiteCredito        Float                @default(0)
  ativo                Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  contasReceber        Conta[]
  documentosFiscais    DocumentoFiscal[]
  movimentacoesFiscais MovimentacaoFiscal[]
  pedidosVenda         PedidoVenda[]
  tabelasPreco         TabelaPreco[]

  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  codigoMunicipio       String?   // IBGE — obrigatório NF-e
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  contribuinteICMS      Boolean   @default(false)
  consumidorFinal       Boolean   @default(false)
}

model Vendedor {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String?
  telefone     String?
  comissao     Float         @default(0)
  metaMensal   Float         @default(0)
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  usuarioId    Int?          @unique
  pedidosVenda PedidoVenda[]
  usuario      Usuario?      @relation(fields: [usuarioId], references: [id])
}

model PedidoCompra {
  id           Int                @id @default(autoincrement())
  numero       String             @unique @default(cuid())
  fornecedorId Int
  status       StatusPedidoCompra @default(RASCUNHO)
  observacao   String?
  valorTotal   Float              @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  itens        ItemPedidoCompra[]
  fornecedor   Fornecedor         @relation(fields: [fornecedorId], references: [id])

  @@index([fornecedorId])
}

model ItemPedidoCompra {
  id             Int          @id @default(autoincrement())
  pedidoCompraId Int
  produtoId      Int
  quantidade     Float
  precoUnitario  Float        @default(0)
  subtotal       Float        @default(0)
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  produto        Produto      @relation(fields: [produtoId], references: [id])

  @@index([pedidoCompraId])
  @@index([produtoId])
}

model PedidoVenda {
  id                   Int                   @id @default(autoincrement())
  numero               String                @unique @default(cuid())
  clienteId            Int
  vendedorId           Int?
  desconto             Float                 @default(0)
  observacao           String?
  valorTotal           Float                 @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  empresaFiscalId      Int?
  tipoPedido           TipoPedido            @default(PEDIDO_NORMAL)
  status               StatusPedido          @default(PEDIDO_CRIADO)
  formaPagamento       FormaPagamento?
  prazoPagamento       String?
  contasReceber        Conta[]
  documentosFiscais    DocumentoFiscal[]
  historico            HistoricoPedido[]
  itens                ItemPedidoVenda[]
  movimentacoesEstoque MovimentacaoEstoque[]
  movimentacoesFiscais MovimentacaoFiscal[]
  cliente              Cliente               @relation(fields: [clienteId], references: [id])
  empresaFiscal        EmpresaFiscal?        @relation(fields: [empresaFiscalId], references: [id])
  vendedor             Vendedor?             @relation(fields: [vendedorId], references: [id])
  separacao            Separacao?

  @@index([clienteId])
  @@index([vendedorId])
  @@index([empresaFiscalId])
  @@index([status])
  @@index([createdAt])
}

model ItemPedidoVenda {
  id            Int         @id @default(autoincrement())
  pedidoVendaId Int
  produtoId     Int
  quantidade    Float
  precoUnitario Float       @default(0)
  desconto      Float       @default(0)
  subtotal      Float       @default(0)
  pedidoVenda   PedidoVenda @relation(fields: [pedidoVendaId], references: [id], onDelete: Cascade)
  produto       Produto     @relation(fields: [produtoId], references: [id])

  @@index([pedidoVendaId])
  @@index([produtoId])
}

model TabelaPreco {
  id        Int               @id @default(autoincrement())
  nome      String
  clienteId Int?
  ativo     Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  itens     ItemTabelaPreco[]
  cliente   Cliente?          @relation(fields: [clienteId], references: [id])

  @@index([clienteId])
}

model ItemTabelaPreco {
  id            Int         @id @default(autoincrement())
  tabelaPrecoId Int
  produtoId     Int
  preco         Float
  descontoMax   Float       @default(0)
  produto       Produto     @relation(fields: [produtoId], references: [id])
  tabelaPreco   TabelaPreco @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)

  @@index([tabelaPrecoId])
  @@index([produtoId])
}

model Separacao {
  id            Int             @id @default(autoincrement())
  pedidoVendaId Int             @unique
  status        StatusSeparacao @default(PENDENTE)
  responsavel   String?
  observacao    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  itens         ItemSeparacao[]
  pedidoVenda   PedidoVenda     @relation(fields: [pedidoVendaId], references: [id])
}

model ItemSeparacao {
  id          Int       @id @default(autoincrement())
  separacaoId Int
  produtoId   Int
  loteId      Int?
  quantidade  Float
  conferido   Boolean   @default(false)
  lote        Lote?     @relation(fields: [loteId], references: [id])
  produto     Produto   @relation(fields: [produtoId], references: [id])
  separacao   Separacao @relation(fields: [separacaoId], references: [id], onDelete: Cascade)

  @@index([separacaoId])
  @@index([produtoId])
  @@index([loteId])
}

model Conta {
  id               Int                  @id @default(autoincrement())
  tipo             TipoConta
  descricao        String
  valor            Float
  valorPago        Float                @default(0)
  dataVencimento   DateTime
  dataPagamento    DateTime?
  status           StatusConta          @default(ABERTA)
  observacao       String?
  formaPagamento   FormaPagamento?
  categoria        String?
  parcelaNumero    Int?
  parcelaTotal     Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  clienteId        Int?
  fornecedorId     Int?
  pedidoVendaId    Int?
  cliente          Cliente?             @relation(fields: [clienteId], references: [id])
  fornecedor       Fornecedor?          @relation(fields: [fornecedorId], references: [id])
  pedidoVenda      PedidoVenda?         @relation(fields: [pedidoVendaId], references: [id])
  historicoPagamentos HistoricoPagamento[]

  @@index([clienteId])
  @@index([fornecedorId])
  @@index([pedidoVendaId])
  @@index([status])
  @@index([dataVencimento])
}

model HistoricoPagamento {
  id             Int             @id @default(autoincrement())
  contaId        Int
  valor          Float
  data           DateTime        @default(now())
  formaPagamento FormaPagamento?
  observacao     String?
  createdAt      DateTime        @default(now())
  conta          Conta           @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
}

model EmpresaFiscal {
  id                   Int                   @id @default(autoincrement())
  razaoSocial          String
  nomeFantasia         String?
  cnpj                 String                @unique
  inscricaoEstadual    String?
  regimeTributario     RegimeTributario?
  ativo                Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  documentosFiscais    DocumentoFiscal[]
  movimentacoesFiscais MovimentacaoFiscal[]
  movimentacoesEstoque MovimentacaoEstoque[]
  pedidosVenda         PedidoVenda[]

  inscricaoMunicipal    String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  municipio             String?
  codigoMunicipio       String?   // código IBGE
  uf                    String?
  cep                   String?

  certificadoPfxBase64  String?   // NUNCA expor em API
  certificadoSenha      String?   // criptografada — NUNCA expor em API
  certificadoValidade   DateTime?

  serieNFe              String    @default("1")
  numeroUltimaNFe       Int       @default(0)
  serieNFSe             String    @default("1")
  numeroUltimaNFSe      Int       @default(0)

  ambienteSEFAZ         String    @default("homologacao")

  codigoTributacaoIss         String?
  codigoNbs                   String?
  aliquotaIss                 Decimal?
  percentualTributosFederais  String? // Used directly as literal string in payload (e.g. "10.38")
  percentualTributosEstaduais String? // Used directly as literal string in payload (e.g. "0.00")
}

model DocumentoFiscal {
  id                   Int                   @id @default(autoincrement())
  tipo                 TipoDocumentoFiscal
  numero               String
  chaveAcesso          String?
  empresaFiscalId      Int
  fornecedorId         Int?
  clienteId            Int?
  pedidoVendaId        Int?
  status               StatusDocumentoFiscal @default(PENDENTE)
  dataEmissao          DateTime?
  createdAt            DateTime              @default(now())
  cliente              Cliente?              @relation(fields: [clienteId], references: [id])
  empresaFiscal        EmpresaFiscal         @relation(fields: [empresaFiscalId], references: [id])
  fornecedor           Fornecedor?           @relation(fields: [fornecedorId], references: [id])
  pedidoVenda          PedidoVenda?          @relation(fields: [pedidoVendaId], references: [id])
  movimentacoesFiscais MovimentacaoFiscal[]

  serie                 String?
  protocolo             String?
  xmlAutorizadoBase64   String?   // XML completo — tem validade jurídica
  danfePdfBase64        String?
  dataAutorizacao       DateTime?

  codigoRejeicao        String?
  mensagemRejeicao      String?

  dataCancelamento      DateTime?
  motivoCancelamento    String?
  xmlCancelamento       String?

  @@index([empresaFiscalId])
  @@index([fornecedorId])
  @@index([clienteId])
  @@index([pedidoVendaId])
}

model MovimentacaoFiscal {
  id                    Int                      @id @default(autoincrement())
  movimentacaoEstoqueId Int                      @unique
  pedidoVendaId         Int?
  clienteId             Int?
  empresaFiscalId       Int
  documentoFiscalId     Int
  produtoId             Int
  loteId                Int?
  quantidade            Float
  valorTotal            Float                    @default(0)
  status                StatusMovimentacaoFiscal @default(PENDENTE)
  dataEmissao           DateTime?
  createdAt             DateTime                 @default(now())
  cliente               Cliente?                 @relation(fields: [clienteId], references: [id])
  documentoFiscal       DocumentoFiscal          @relation(fields: [documentoFiscalId], references: [id])
  empresaFiscal         EmpresaFiscal            @relation(fields: [empresaFiscalId], references: [id])
  lote                  Lote?                    @relation(fields: [loteId], references: [id])
  movimentacaoEstoque   MovimentacaoEstoque      @relation(fields: [movimentacaoEstoqueId], references: [id])
  pedidoVenda           PedidoVenda?             @relation(fields: [pedidoVendaId], references: [id])
  produto               Produto                  @relation(fields: [produtoId], references: [id])

  @@index([pedidoVendaId])
  @@index([clienteId])
  @@index([empresaFiscalId])
  @@index([documentoFiscalId])
  @@index([produtoId])
  @@index([loteId])
}

model HistoricoPedido {
  id             Int           @id @default(autoincrement())
  pedidoVendaId  Int
  statusAnterior StatusPedido?
  statusNovo     StatusPedido
  usuarioId      Int?
  setor          PerfilUsuario?
  tipoAcao       String?
  observacao     String?
  createdAt      DateTime      @default(now())
  pedidoVenda    PedidoVenda   @relation(fields: [pedidoVendaId], references: [id])
  usuario        Usuario?      @relation(fields: [usuarioId], references: [id])

  @@index([pedidoVendaId])
  @@index([usuarioId])
  @@index([createdAt])
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE
  RESERVA
  BLOQUEIO
  PERDA
  TRANSFERENCIA
  CANCELAMENTO_RESERVA
  DEVOLUCAO
}

enum StatusEstoque {
  DISPONIVEL
  RESERVADO
  BLOQUEADO
  VENCIDO
  QUARENTENA
}

enum TipoDocumentoFiscal {
  NFE_ENTRADA
  NFE_SAIDA
  NFSE
  AJUSTE
}

enum StatusDocumentoFiscal {
  PENDENTE
  AUTORIZADA
  REJEITADA
  CANCELADA
}

enum StatusMovimentacaoFiscal {
  PENDENTE
  AUTORIZADA
  CANCELADA
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum StatusPedidoCompra {
  RASCUNHO
  ENVIADO
  PARCIAL
  RECEBIDO
  CANCELADO
}

enum FormaPagamento {
  PIX
  BOLETO
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
  TRANSFERENCIA
  A_PRAZO
  CHEQUE
}

enum TipoPedido {
  PEDIDO_NORMAL
  PEDIDO_INTERNO
}

enum StatusPedido {
  PEDIDO_CRIADO
  AGUARDANDO_ESTOQUE
  ESTOQUE_CONFIRMADO
  ESTOQUE_PARCIAL
  ESTOQUE_INDISPONIVEL
  AGUARDANDO_FORNECEDOR
  AGUARDANDO_APROVACAO_FINANCEIRA
  APROVADO_FINANCEIRO
  REPROVADO_FINANCEIRO
  PAGAMENTO_PENDENTE
  CONDICAO_COMERCIAL_PENDENTE
  AGUARDANDO_CONFIRMACAO_CLIENTE
  CLIENTE_CONFIRMOU
  PEDIDO_EM_REVISAO
  AGUARDANDO_FATURAMENTO
  PEDIDO_INTERNO_AUTORIZADO
  AUTORIZADO_PARA_SEPARACAO
  EM_SEPARACAO
  SEPARADO
  FATURADO
  DESPACHADO
  FINALIZADO
  CANCELADO
  CANCELADO_PELO_CLIENTE
}

enum StatusSeparacao {
  PENDENTE
  EM_ANDAMENTO
  CONFERIDO
  DESPACHADO
}

enum TipoConta {
  RECEBER
  PAGAR
}

enum StatusConta {
  ABERTA
  PAGA
  VENCIDA
  CANCELADA
}

enum PerfilUsuario {
  ADMINISTRADOR
  VENDAS
  ESTOQUE
  FINANCEIRO
}
